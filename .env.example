POSTGRES_DB=fpvhub
POSTGRES_USER=fpvhub
POSTGRES_PASSWORD=fpvhub

# Stage 7: real external email validation through AbstractAPI.
# Keep disabled for local smoke tests without an API key.
EMAIL_VALIDATION_ENABLED=false
EMAIL_VALIDATION_FAIL_OPEN=true
EMAIL_VALIDATION_API_URL=https://emailreputation.abstractapi.com/v1/
EMAIL_VALIDATION_API_KEY=
EMAIL_VALIDATION_PROXY_HOST=
EMAIL_VALIDATION_PROXY_PORT=0

# Stage 7: manual GitHub OAuth without Spring OAuth client.
GITHUB_OAUTH_ENABLED=false
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
GITHUB_OAUTH_REDIRECT_URI=http://localhost:8080/oauth2/github/callback
